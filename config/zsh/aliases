# ls
alias ls='lsd'
alias la='lsd -a'
alias lt='lsd --tree'
alias lla='lsd -la'

# vim
alias vim='\nvim'
alias vi='\vim'

# bat
alias batview="fzf --preview 'bat --color=always --style=numbers --line-range=:500 {}'"
alias batdiff="git diff --name-only --relative --diff-filter=d | xargs bat --diff"
alias bathelp='bat --plain --language=help'

# others
alias lg='lazygit'
alias top='btm'
alias sync='rsync -uvrP --delete-after'
alias ec='ebook-convert'
alias uvs='source .venv/bin/activate'
alias oscad='/Applications/OpenSCAD.app/Contents/MacOS/OpenSCAD'
