font-family = "Berkeley Mono Medium"
font-family-bold = "Berkeley Mono Bold"
font-family-italic = "Berkeley Mono Medium Oblique"
font-family-bold-italic = "Berkeley Mono Bold Oblique"
font-family = "Hack Nerd Font Mono"
font-thicken = true
theme = Catppuccin Mocha
shell-integration-features = no-cursor,ssh-terminfo,ssh-env
cursor-style = "block"
background-opacity = 0.92
font-size = 18
window-padding-x = 5
window-padding-y = 5,2
window-decoration = client
macos-titlebar-style = hidden
cursor-style-blink = false
scrollback-limit = 10000000
custom-shader = shaders/cursor.glsl
gtk-single-instance = true
